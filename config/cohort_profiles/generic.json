{
  "profile_id": "generic",
  "display_name": "Generic trial (zero-shot)",
  "description": "No criterion catalog. LLM parse + generic post-processing only.",
  "index_patterns": ["mimic_*", "emr_*", "trialgpt_*", "test_*"],
  "criteria": [],
  "parse_pipeline": {
    "merge_chia_fallback": true,
    "normalize_lab_tests": true,
    "extract_lab_ranges_from_query": true,
    "strip_bad_medication_tokens": true,
    "l1_prompt_variant": "unified"
  },
  "routing": {
    "default_l4": true,
    "judge_when_fields": [
      "inclusion_logic",
      "composite_min_count",
      "temporal_event",
      "inclusion_terms",
      "required_medications"
    ],
    "judge_never_lab_only": true
  },
  "judge": {
    "enabled": true,
    "batch_size": 5
  },
  "layer5_analysis": {
    "enabled": true,
    "max_patients_in_report": 5
  }
}
