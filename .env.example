LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com

APP_API_KEY=
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=logs/audit.log
DESENSITIZE_RESPONSES=false

ES_HOST=http://localhost:9200
ES_INDEX=emr_cardiometabolic
ALLOWED_ES_INDICES=emr_cardiometabolic,emr_oncology,emr_respiratory,emr_nephrology,emr_neuropsychiatric,emr_records
ES_QUERY_TIMEOUT=3s
ES_MAX_RESULT_SIZE=50
ENABLE_TWO_STAGE_SEARCH=true
ES_RECALL_SIZE=100

POST_PROCESS_TIMEOUT_SECONDS=3
POST_PROCESS_MAX_ROWS=1000
POST_PROCESS_MAX_CODE_CHARS=12000

# Credentialed datasets (required for offline eval only; not needed for live demo)
# n2c2 2018 Track 1 cohort-selection directory (contains n2c2-t1_gold_standard_test_data/...)
N2C2_DATA_ROOT=
# Chia brat corpus root (e.g. .../chia_without_scope)
CHIA_DATA_ROOT=
# n2c2 2018 Track 2 root (optional; drug lexicon / Track 2 eval)
N2C2_TRACK2_DATA_ROOT=
